grid-columns: 6
grid-rows: 1
grid-gap: 0

entry: {
  label: "CLI / API"
  style.fill: "#eff1f5"
  style.stroke: "#8839ef"
  style.font-color: "#4c4f69"
  style.border-radius: 8
  style.font-size: 13
}

runtime: {
  label: "runtime/\nisolate.rs"
  style.fill: "#eff1f5"
  style.stroke: "#8839ef"
  style.font-color: "#4c4f69"
  style.border-radius: 8
  style.font-size: 12
}

logic: {
  label: "verdict  config  observability"
  style.fill: "#eff1f5"
  style.stroke: "#40a02b"
  style.font-color: "#4c4f69"
  style.border-radius: 8
  style.font-size: 12
}

process: {
  label: "core/supervisor\nexec/typestate"
  style.fill: "#e6e9ef"
  style.stroke: "#1e66f5"
  style.font-color: "#4c4f69"
  style.border-radius: 8
  style.font-size: 12
}

kernel: {
  label: "kernel/\nunsafe wrappers"
  style.fill: "#4c4f69"
  style.stroke: "#fe640b"
  style.font-color: "#eff1f5"
  style.border-radius: 8
  style.font-size: 12
}

safety: {
  label: "safety/\nutils/"
  style.fill: "#eff1f5"
  style.stroke: "#8839ef"
  style.font-color: "#4c4f69"
  style.border-radius: 8
  style.font-size: 12
}

entry -> runtime -> logic -> process -> kernel -> safety
