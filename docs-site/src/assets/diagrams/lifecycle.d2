direction: right

setup: {
  label: "new()"
  style.fill: "#eff1f5"
  style.stroke: "#8839ef"
  style.font-color: "#4c4f69"
  style.border-radius: 6
  style.font-size: 12
}

compile: {
  label: "compile"
  style.fill: "#eff1f5"
  style.stroke: "#8839ef"
  style.font-color: "#4c4f69"
  style.border-radius: 6
  style.font-size: 12
}

supervise: {
  label: ""
  style.fill: "#e6e9ef"
  style.stroke: "#1e66f5"
  style.border-radius: 8

  supervisor: {
    label: "Supervisor"
    style.fill: "#e6e9ef"
    style.stroke: "#1e66f5"
    style.font-color: "#4c4f69"
    style.border-radius: 6
    style.font-size: 12
  }

  proxy: {
    label: "Proxy"
    style.fill: "#e6e9ef"
    style.stroke: "#1e66f5"
    style.font-color: "#4c4f69"
    style.border-radius: 6
    style.font-size: 12
  }

  payload: {
    label: "User Code"
    style.fill: "#fe640b"
    style.stroke: "#fe640b"
    style.font-color: "#ffffff"
    style.border-radius: 6
    style.font-size: 12
    style.bold: true
  }

  supervisor -> proxy -> payload
}

evidence: {
  label: "evidence"
  style.fill: "#eff1f5"
  style.stroke: "#40a02b"
  style.font-color: "#4c4f69"
  style.border-radius: 6
  style.font-size: 12
}

verdict: {
  label: "verdict"
  style.fill: "#eff1f5"
  style.stroke: "#40a02b"
  style.font-color: "#4c4f69"
  style.border-radius: 6
  style.font-size: 12
}

cleanup: {
  label: "cleanup()"
  style.fill: "#eff1f5"
  style.stroke: "#8839ef"
  style.font-color: "#4c4f69"
  style.border-radius: 6
  style.font-size: 12
}

setup -> compile -> supervise -> evidence -> verdict -> cleanup
