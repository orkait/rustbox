direction: down

setup: {
  label: "Isolate::new()"
  tooltip: "Allocate UID, create cgroup, capture baseline"
  style.fill: "#eff1f5"
  style.stroke: "#8839ef"
  style.font-color: "#4c4f69"
  style.border-radius: 8
  style.font-size: 14
}

compile: {
  label: "Compile (if needed)"
  tooltip: "C++: g++ outside sandbox. Java: javac"
  style.fill: "#eff1f5"
  style.stroke: "#8839ef"
  style.font-color: "#4c4f69"
  style.border-radius: 8
  style.font-size: 14
}

supervisor: {
  label: "Supervisor"
  tooltip: "clone() into new namespaces"
  style.fill: "#e6e9ef"
  style.stroke: "#1e66f5"
  style.font-color: "#4c4f69"
  style.border-radius: 8
  style.font-size: 14
}

proxy: {
  label: "Proxy"
  tooltip: "fork() payload through typestate chain"
  style.fill: "#e6e9ef"
  style.stroke: "#1e66f5"
  style.font-color: "#4c4f69"
  style.border-radius: 8
  style.font-size: 14
}

sandbox: {
  label: "Sandbox"
  style.fill: "#4c4f69"
  style.stroke: "#fe640b"
  style.font-color: "#eff1f5"
  style.border-radius: 12

  payload: {
    label: "User Code"
    style.fill: "#fe640b"
    style.stroke: "#e64553"
    style.font-color: "#ffffff"
    style.border-radius: 8
    style.font-size: 14
    style.bold: true
  }
}

evidence: {
  label: "Evidence Collection"
  tooltip: "cgroup stats, wait status, timing"
  style.fill: "#eff1f5"
  style.stroke: "#40a02b"
  style.font-color: "#4c4f69"
  style.border-radius: 8
  style.font-size: 14
}

verdict: {
  label: "Verdict Classification"
  tooltip: "Pure function: evidence bundle → verdict"
  style.fill: "#eff1f5"
  style.stroke: "#40a02b"
  style.font-color: "#4c4f69"
  style.border-radius: 8
  style.font-size: 14
}

cleanup: {
  label: "Isolate::cleanup()"
  tooltip: "Verify baseline, remove cgroup, wipe workdir, release UID"
  style.fill: "#eff1f5"
  style.stroke: "#8839ef"
  style.font-color: "#4c4f69"
  style.border-radius: 8
  style.font-size: 14
}

setup -> compile: "write source" {style.font-color: "#5c5f77"; style.font-size: 11}
compile -> supervisor: "clone()" {style.font-color: "#5c5f77"; style.font-size: 11}
supervisor -> proxy: "fork()" {style.font-color: "#5c5f77"; style.font-size: 11}
proxy -> sandbox.payload: "typestate chain → exec()" {style.font-color: "#5c5f77"; style.font-size: 11}
sandbox.payload -> evidence: "exit / killed" {style.font-color: "#5c5f77"; style.font-size: 11}
evidence -> verdict: "immutable bundle" {style.font-color: "#5c5f77"; style.font-size: 11}
verdict -> cleanup {style.font-color: "#5c5f77"}

supervisor -> sandbox.payload: "monitors wall + CPU time" {
  style.stroke: "#e64553"
  style.stroke-dash: 5
  style.font-size: 11
  style.font-color: "#e64553"
}
